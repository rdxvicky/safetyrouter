# SafetyRouter — Environment Configuration
# Copy this file to .env and fill in your API keys.
# Only the keys for providers you actually use are required.

# --- Classifier (always required — runs locally via Ollama) ---
# Default: gemma3n:e2b (5.6 GB). Use gemma3n:e4b for higher accuracy.
# CLASSIFIER_MODEL=gemma3n:e2b

# --- Provider API Keys (optional — only needed for providers you route to) ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...
GROQ_API_KEY=gsk_...       # Free tier available at console.groq.com

# --- Model Overrides (optional) ---
# OPENAI_MODEL=gpt-4o
# ANTHROPIC_MODEL=claude-opus-4-6
# GOOGLE_MODEL=gemini-1.5-pro
# GROQ_MODEL=mixtral-8x7b-32768
# OLLAMA_MODEL=llama3.2

# --- Local Ollama (for OllamaProvider target) ---
# OLLAMA_HOST=http://localhost:11434
